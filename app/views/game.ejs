<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head') %>
  <style>
    #promotion-layer {
      display: none;
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.7);
      z-index: 9999;
      justify-content: center;
      align-items: center;
    }
    .promotion-options {
      background: #f0d9b5;
      padding: 20px;
      border-radius: 8px;
      display: flex;
      gap: 15px;
      border: 4px solid #b58863;
    }
    .promotion-options img {
      width: 80px;
      height: 80px;
      cursor: pointer;
      transition: transform 0.2s, background 0.2s;
      border-radius: 4px;
    }
    .promotion-options img:hover {
      background: #b58863;
      transform: scale(1.1);
    }

    #myBoard {
      width: 80%;    
      margin: 0 auto; 
    }

    .pane-middle {
      display: flex;
      flex-direction: column;
      align-items: center; /* Center children vertically/horizontally */
    }

    #top_player, #bottom_player {
      width: 80%; /* Match board width for alignment */
      text-align: left;
      margin: 5px 0;
    }
  </style>
<body>
  <header class="navbar">
    <div class="left-group">
      <%- include('partials/logo') %> 
      <%- include('partials/nav') %>
    </div>
  </header>

  <div id="promotion-layer">
    <div class="promotion-options" id="promotion-choices"></div>
  </div>

  <div class="container">
    <aside class="pane pane-left">
          <% if (player) {%>
          <table><tbody>
          <tr><td><%= player.name %> <%= player.lastname %></td></tr>
          </tbody></table>
          <% } %>
       <table>
         <tbody>
          <tr><td><div id="evaluation" class="eval">Eval:</div></td></tr>
          <tr><td><canvas id="graph" width="280" height="100"></canvas></td></tr>
          <tr><td><div><strong>Min:</strong> <%=info[0].eval_min %> <strong>Max: </strong> <%=info[0].eval_max %></div></td></tr>
        </tbody>
      </table>
    </aside>

    <section class="pane pane-middle">
      <table style="width: 100%;">
        <tbody>
          <tr>
             <td><button id="flipBoardBtn" class="flip" >Flip Board</button></td>
             <td><div><strong>Time Control:</strong> <%= info[0].time_control %> </div>
                 <div><strong>Result:</strong> <%= info[0].result %> (<%= info[0].termination %>)</div>
                 <div><strong>Opening:</strong> <%= info[0].eco %> <%= info[0].name %></div>
                 <div id="fen-text" class="fen-display">FEN: Loading...</div> 
             </td>
          </tr>
        </tbody>
      </table>

      <div id="top_player">
        <strong><%= info[0].black %></strong> (<%= info[0].black_elo %>)
      </div>

      <div id="myBoard"></div>

      <div id="bottom_player">
        <strong><%= info[0].white %></strong> (<%= info[0].white_elo %>)
      </div>
    </section>

    <aside class="pane pane-right">
      <div><h3>Moves</h3></div>
      <hr style="border: 0.5px solid #383531;">
      <div id="move-list" class="move-history">
        <div class="move-item active" id="move-0" onclick="goToMove(-1)">Start</div>
        <% moves.forEach((move, index) => { %>
          <div class="move-item" id="move-<%= index + 1 %>" onclick="goToMove(<%= index %>)">
            <%= index + 1 %>. <%= move.short_notation %>
          </div>
        <% }) %>
      </div>
    </aside>
  </div>

  <script>
    
    (function() {
      const canvas = document.getElementById('graph');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const moves = <%- JSON.stringify(moves) %>;
      const validData = moves.filter(m => {
        const fin = parseFloat(m.final_eval);
        return !isNaN(fin) && fin !== 0;
      });
      if (validData.length === 0) return;
      const padding = 10;
      const width = canvas.width - (padding * 2);
      const height = canvas.height - (padding * 2);
      let maxVal = 0;
      validData.forEach(m => { maxVal = Math.max(maxVal, Math.abs(parseFloat(m.final_eval))); });
      maxVal = maxVal || 10;
      const getX = (i) => padding + (i * (width / (validData.length - 1 || 1)));
      const getY = (v) => (canvas.height / 2) - ((v / maxVal) * (height / 2));
      ctx.beginPath();
      ctx.strokeStyle = 'brown';
      ctx.moveTo(padding, canvas.height / 2);
      ctx.lineTo(canvas.width - padding, canvas.height / 2);
      ctx.stroke();
      ctx.beginPath();
      ctx.strokeStyle = 'gray';
      ctx.lineWidth = 2;
      validData.forEach((m, i) => {
        const x = getX(i); const y = getY(parseFloat(m.final_eval));
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      });
      ctx.stroke();
    })();
  </script>

  <script>
    const info     = <%- JSON.stringify(info) %>;
    const mainLine = <%- JSON.stringify(moves) %>;
    const startFen = "<%= startFen %>";
    
    let currentIndex = -1; 
    let board = null;
    let game = new Chess();

    function rotate() {
      board.flip();
      const topHtml = $('#top_player').html();
      const bottomHtml = $('#bottom_player').html();
      $('#top_player').html(bottomHtml);
      $('#bottom_player').html(topHtml);
    }

    function updateUI() {
        const currentFen = currentIndex === -1 ? startFen : mainLine[currentIndex].fen;
        const currentEval = currentIndex === -1 ? 0 : mainLine[currentIndex].final_eval;

        const isCheck = currentIndex === -1 ? 0 : mainLine[currentIndex].incheck;
        const isMate  = currentIndex === -1 ? 0 : mainLine[currentIndex].mate;
 
        board.position(currentFen);
        game.load(currentFen);
        $('#fen-text').text('FEN: ' + currentFen);

        if (isMate === 1) {
          $('#evaluation').text('Eval: Mate');
        } else if (isCheck === 1) {
          $('#evaluation').text('Eval: Check');
        } else {
          $('#evaluation').text('Eval: ' + currentEval);
        }

        $('.move-item').removeClass('active');
        $(`#move-${currentIndex + 1}`).addClass('active');
    }

    function goToMove(index) {
        if (index >= -1 && index < mainLine.length) {
            currentIndex = index;
            updateUI();
        }
    }
    
    function showPromotionMenu(color, source, target) {
      const pieces = ['q', 'r', 'b', 'n'];
      const $menu = $('#promotion-choices').empty();
      const theme = 'https://chessboardjs.com/img/chesspieces/wikipedia/';

      pieces.forEach(p => {
        const imgSrc = `${theme}${color}${p.toUpperCase()}.png`;
        const $img = $(`<img src="${imgSrc}">`).on('click', function() {
          finalizePromotion(source, target, p);
        });
        $menu.append($img);
      });

      $('#promotion-layer').css('display', 'flex');
    }

    function finalizePromotion(source, target, piece) {
      $('#promotion-layer').hide();
      game.move({ from: source, to: target, promotion: piece });
      board.position(game.fen());
      $('#fen-text').text('FEN (Analysis): ' + game.fen());
    }

    function onDrop (source, target) {
        const piece = game.get(source);
        if (piece && piece.type === 'p') {
            const isWhitePromotion = piece.color === 'w' && target[1] === '8';
            const isBlackPromotion = piece.color === 'b' && target[1] === '1';
            
            if (isWhitePromotion || isBlackPromotion) {
                const tempGame = new Chess(game.fen());
                const move = tempGame.move({ from: source, to: target, promotion: 'q' });
                if (!move) return 'snapback';

                showPromotionMenu(piece.color, source, target);
                return; 
            }
        }

        let move = game.move({ from: source, to: target });
        if (move === null) return 'snapback';
        $('#fen-text').text('FEN (Analysis): ' + game.fen());
    }

    function onDragStart (source, piece) {
        if (game.game_over()) return false;
        if ((game.turn() === 'w' && piece.search(/^b/) !== -1) ||
            (game.turn() === 'b' && piece.search(/^w/) !== -1)) {
            return false;
        }
    }

    const config = {
        draggable: true,
        position: startFen,
        onDragStart: onDragStart,
        onDrop: onDrop,
        pieceTheme: 'https://chessboardjs.com/img/chesspieces/wikipedia/{piece}.png'
    };

    board = Chessboard('myBoard', config);
    
    $(window).on('resize', board.resize);

    if (info && info[0].side == 0) rotate();
    $('#flipBoardBtn').on('click', rotate);
    updateUI();   

    $(document).keydown(e => {
        if (e.keyCode == 37) goToMove(currentIndex - 1);
        if (e.keyCode == 39) goToMove(currentIndex + 1);
    });
  </script>
</body>
</html>
