<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head') %>
<body>

  <header class="navbar">
    <div class="left-group">
      <%- include('partials/logo') %> 
      <%- include('partials/nav') %>
    </div>
  </header>

  <div class="container">
    <aside class="pane pane-left">
      <table>
        <tbody>
          <th>Players</th>
           <% if (playerList.length > 0) { %>
             <% playerList.forEach(player => { %>
                <tr>
                  <td><a href="/player?id=<%= player.id %>"> <%= player.name %> <%= player.lastname %></a></td>
                </tr>
             <% }); %>
           <% } else { %>
              <tr>
                <td>No players found.</td>
              </tr>
           <% } %>
           <tr>
             <td>
               <form action="/player/add" method="GET">
                 <button type="submit" name="action" class="add">Add</button>
               </form>
             </td>
             <td><!-- --></td>
           </tr>
        </tbody>
      </table>
    </aside>

    <section class="pane pane-middle">
      <% if (accountList.length === 0 ) { %>
        <div>No chess acounts found. Please click on players, and add chess account.</div>
      <% } else { %>
        <div>
          <% if (gameList.length === 0) { %>
            No games found in the database. If cronjobs are set, they should be downloaded after midnight. 
          <% } else {%>
           <table>
             <thead>
               <tr>
                 <th>White</th>
                 <th>Black</th>
                 <th>Result</th>
                 <th>Time Control</th>
                 <th>ECO</th>
                 <th>Opening</th>
               </tr>
             </thead>
             <tbody>
               <% gameList.forEach(game => { %>
                 <tr>
                   <td><%= game.white %></td>
                   <td><%= game.black %></td>
                   <td><%= game.result %></td>
                   <td><%= game.time_control %></td>
                   <td><%= game.eco %></td>
                   <td><%= game.name %></td>
                 </tr>
               <% }) %>
             </tbody>
           </table>
          <% } %>
        </div>
      <% } %>
    </section>
    <aside class="pane pane-right">
      <div class=""></div>
    </aside>
  </div>

</body>
</html>
